function ufo() {
  push();
  fill("lightSlateGray");
  stroke(0,0,0,30);
  translate(0, -750, -25);
  //it would be more fun if this thing moved
  rotateY(angle);
  //ufo orb
  sphere(90);
  //ufo saucer
  ellipsoid(200, 25, 200, 24 , 10);
  pop();
  //the beam is green
  push();
  fill(0, 255, 0, 35);
  noStroke();
  //move the beam over the cow
  translate(0, -175, -25);
  //flip the beam in the right direction
  rotateX(180);
  //why use numbers when you can use variables?
  let coneRadius = 400;
  let coneHeight = 975;
  cone(coneRadius, coneHeight, 24, 20);
  //ufo rotation speed
  angle += 0.6;
pop();
}
