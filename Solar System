function kuiperBelt() {
  push();
  //orbital rotation
  rotateY(frameCount * 0.00001);
  //use the loop to create our unique TNOs
  for (let obj of TNOs) {
    push();
    //place it in the unique location
    translate(obj.x, obj.y, obj.z);
    ambientMaterial(200);
    sphere(obj.size);
    pop();  
  }
  pop();
}
