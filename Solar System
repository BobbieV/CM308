function asteroidBelt() {
  push();
  //orbital rotation speed
  rotateY(frameCount * 0.01);
  
  for (let obj of ABOs) {
    push();
    translate(obj.x, obj.y, obj.z);
    specularMaterial(200);
    sphere(obj.size);
    pop(); 
  }
  pop();  
}

