let angle = 1;

function setup() {
  createCanvas(600, 600, WEBGL);
  angleMode(DEGREES);
}

function draw() {
  background("lightblue");
  orbitControl();
  
  // grass
  push();
  //put the grass on the ground
  translate(0, 325, 0); 
  rotateX(90);
  fill("green");
  plane(100000, 100000);
  pop();

  cow();
  ufo();
}

